#!/usr/bin/env bash

# post-checkout hook
# When switching TO the `next` branch, automatically rebase it on top of `main`
# (or `origin/main` on machines that keep only `next` locally).
#
# Hook arguments:
#   $1 = previous HEAD ref
#   $2 = new HEAD ref
#   $3 = checkout type: 1 = branch checkout, 0 = file checkout

CHECKOUT_TYPE="$3"

# Only act on branch checkouts, not file checkouts
if [ "$CHECKOUT_TYPE" != "1" ]; then
  exit 0
fi

CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$CURRENT_BRANCH" != "next" ]; then
  exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel)

# Source common functions
# shellcheck disable=SC1091
source "${REPO_ROOT}/.githooks/common.sh"

# Determine the base ref: prefer a local `main`, fall back to `origin/main`
# (supports machines that keep only `next` locally).
if git rev-parse --verify main > /dev/null 2>&1; then
  BASE_REF=main
elif git rev-parse --verify origin/main > /dev/null 2>&1; then
  BASE_REF=origin/main
else
  step_skip "auto-rebase skipped: neither 'main' nor 'origin/main' found"
  exit 0
fi

# Bail out if index or working tree is dirty (rebase would fail anyway)
if ! git diff --quiet || ! git diff --cached --quiet; then
  step_skip "auto-rebase skipped: working tree has uncommitted changes"
  exit 0
fi

step_exec "Rebasing 'next' on top of '${BASE_REF}'..."
if git rebase "$BASE_REF" > /dev/null 2>&1; then
  step_done "Rebased 'next' on top of '${BASE_REF}'"
else
  printf '%s' "$CLEAR_LINE"
  git rebase --abort > /dev/null 2>&1
  print_status "$YELLOW" " WARN " "auto-rebase failed (conflicts?) — aborted. Rebase manually: git rebase ${BASE_REF}"
fi

exit 0
