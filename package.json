{
  "name": "electrolux-to-mqtt",
  "version": "development",
  "description": "TypeScript bridge from the Electrolux appliance API to MQTT, with Home Assistant auto-discovery.",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "check": "pnpm biome check --write",
    "clean": "rimraf node_modules",
    "dev:docker": "NODE_VERSION=$(cat .nvmrc) docker compose -f docker/docker-compose.local.yml down && NODE_VERSION=$(cat .nvmrc) docker compose -f docker/docker-compose.local.yml up --build",
    "backend:docker": "NODE_VERSION=$(cat .nvmrc) docker compose -f telemetry-backend/docker-compose.yml down && NODE_VERSION=$(cat .nvmrc) docker compose -f telemetry-backend/docker-compose.yml up --build",
    "dev": "tsx watch src/index.ts",
    "format": "pnpm biome format --write",
    "lint": "pnpm biome lint --write",
    "nuke": "pnpm clean ; pnpm install",
    "postinstall": "{ [ -f /.dockerenv ] || [ -n \"$CI\" ] || [ -n \"$DOCKER_BUILD\" ]; } && exit 0; bash .githooks/postinstall.sh || exit 0",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tests.json",
    "test": "vitest run --coverage",
    "test:e2e": "E2E_TEST=true vitest run tests/e2e/*.test.ts",
    "test:watch": "vitest",
    "sonar": "sh scripts/sonar.sh",
    "osv-scan": "sh scripts/osv-scan.sh",
    "deps:check": "pnpm outdated ; pnpm audit ; pnpm osv-scan",
    "deps:update": "pnpm update --latest && pnpm install",
    "sops:decrypt": "scripts/sops-env.sh decrypt",
    "sops:encrypt": "scripts/sops-env.sh encrypt",
    "sops:rotate": "scripts/sops-rotate.sh",
    "sops:sync-ci": "scripts/sync-ci-age-key.sh",
    "gitlab:rotate-pat": "scripts/rotate-gitlab-pat.sh",
    "sync:versions": "bash scripts/sync-versions.sh"
  },
  "keywords": [
    "electrolux",
    "home-assistant",
    "homeassistant",
    "mqtt",
    "iot",
    "smart-home"
  ],
  "author": "Kimmo Saari <kirbo@kirbo-designs.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "dependencies": {
    "axios": "^1.18.1",
    "mqtt": "^5.15.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tiny-lru": "^13.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
