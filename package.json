{
  "name": "electrolux-to-mqtt",
  "version": "development",
  "description": "",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "check": "pnpm biome check --write",
    "clean": "rimraf node_modules",
    "dev:docker": "NODE_VERSION=$(cat .nvmrc) docker compose -f docker/docker-compose.local.yml down && NODE_VERSION=$(cat .nvmrc) docker compose -f docker/docker-compose.local.yml up --build",
    "backend:docker": "NODE_VERSION=$(cat .nvmrc) docker compose -f telemetry-backend/docker-compose.yml down && NODE_VERSION=$(cat .nvmrc) docker compose -f telemetry-backend/docker-compose.yml up --build",
    "dev": "tsx watch src/index.ts",
    "format": "pnpm biome format --write",
    "lint": "pnpm biome lint --write",
    "nuke": "pnpm clean ; pnpm install",
    "postinstall": "{ [ -f /.dockerenv ] || [ -n \"$CI\" ] || [ -n \"$DOCKER_BUILD\" ]; } && exit 0; bash .githooks/postinstall.sh || exit 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:e2e": "E2E_TEST=true vitest run tests/e2e/*.test.ts",
    "test:watch": "vitest",
    "sonar": "[ -f .env ] && export $(grep -v '^#' .env | xargs) ; sonar-scanner",
    "deps:check": "pnpm outdated ; pnpm audit",
    "deps:update": "pnpm update --latest && pnpm install"
  },
  "keywords": [],
  "author": "Kimmo Saari <kirbo@kirbo-designs.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "dependencies": {
    "axios": "^1.14.0",
    "mqtt": "^5.15.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tiny-lru": "^13.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "7.3.2",
    "vitest": "^4.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ],
    "overrides": {
      "picomatch": ">=4.0.4"
    }
  }
}
