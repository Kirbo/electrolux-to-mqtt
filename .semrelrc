{
  "plugins": {
    "commit-analyzer": {
      "options": {
        "patch_release_rules": "fix,chore(deps)"
      }
    },
    "ci-condition": {
      "name": "default"
    },
    "changelog-generator": {
      "name": "default"
    },
    "provider": {
      "name": "gitlab"
    }
  },
  "maintainedVersion": "next"
}
