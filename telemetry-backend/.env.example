# telemetry-backend — SOPS-managed secrets.
# These are the values that live in telemetry-backend/.env.enc (encrypted with age).
# Run `pnpm sops:encrypt` to produce .env.enc from this .env, then commit only .env.enc.
# Run `pnpm sops:decrypt` to regenerate .env from .env.enc when deploying.
#
# NON-SECRET env (APTABASE_APP_KEY, APTABASE_HOST, PORT, BADGE_INTERVAL_SECONDS,
# RATE_LIMIT_*) lives in docker-compose.yml — no need to put those here.

# --- Required ---
# Aptabase app GUID — NOT the App-Key (A-SH-...).
# Find it in Aptabase's dashboard or `apps` table in Postgres.
APTABASE_APP_ID=

# ClickHouse HTTP endpoint, reached over the shared Aptabase docker network.
# For the standard self-hosted stack the ClickHouse service is on port 8123:
CLICKHOUSE_URL=http://aptabase_events_db:8123

# --- ClickHouse auth (use a read-only user) ---
CLICKHOUSE_USER=badge_reader
CLICKHOUSE_PASSWORD=

# --- Optional (code defaults shown; uncomment to override) ---
# ClickHouse database holding Aptabase's `events` table (often `default`).
# CLICKHOUSE_DATABASE=default
