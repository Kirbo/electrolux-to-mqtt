# Telemetry backend environment variables.
# Copy this file to .env and fill in values before running docker-compose.

# Server port. docker-compose.yml sets this inline; override here only if needed.
# PORT=3001

# Redis connection URL. docker-compose.yml sets this inline to the service name.
# REDIS_URL=redis://redis:6379

# Secret salt used to hash IPs for rate limiting. If unset, falls back to the
# host /etc/machine-id (mounted read-only by docker-compose.yml). Set an explicit
# random secret for extra security (e.g. openssl rand -hex 32).
# RATE_LIMIT_SALT=change-me-to-a-random-secret

# Rate limit window in milliseconds. Default: 60000 (1 minute).
# RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per source IP per window. Default: 10.
# RATE_LIMIT_IP_MAX=10

# Maximum requests per userHash per window. Default: 1.
# RATE_LIMIT_HASH_MAX=1

# Set to true/1/yes ONLY when deployed behind a trusted reverse proxy that
# overwrites client-supplied X-Forwarded-For headers (Caddy, nginx, Traefik).
# Default: false (raw TCP source address used — safe for direct exposure).
# TELEMETRY_BEHIND_PROXY=false

# Circuit-breaker: consecutive Redis rate-limit failures before the breaker opens.
# Default: 5. When open, /telemetry returns 503 until the breaker resets.
# RATE_LIMIT_BREAKER_THRESHOLD=5

# Rolling window for counting breaker failures (ms). Default: 60000.
# RATE_LIMIT_BREAKER_WINDOW_MS=60000

# How long the breaker stays open before testing recovery (ms). Default: 30000.
# RATE_LIMIT_BREAKER_COOLDOWN_MS=30000

# Set to true to accept test-hash payloads without storing (used by e2e tests).
# Default false. Opt-in: export ALLOW_TEST_TELEMETRY=true (or add it here) before
# running docker compose up when running e2e tests against your local stack.
# ALLOW_TEST_TELEMETRY=false
