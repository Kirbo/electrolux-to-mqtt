{
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "PATH=\"/Users/kimmo.saari/.local/share/fnm/node-versions/v24.14.1/installation/bin:$PATH\" pnpm check",
            "timeout": 60,
            "statusMessage": "Running pnpm check before commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "read -r input; fp=$(echo \"$input\" | jq -r '.tool_input.file_path'); root=$(git -C \"$(dirname \"$fp\")\" rev-parse --show-toplevel 2>/dev/null); [[ -n \"$root\" && \"$fp\" == \"$root\"/* ]] && cd \"$root\" && pnpm check 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Running pnpm check..."
          }
        ]
      }
    ]
  }
}
